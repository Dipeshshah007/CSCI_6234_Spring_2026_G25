@startuml PayFine
skinparam backgroundColor white
skinparam SequenceBoxBackgroundColor white
skinparam SequenceBoxBorderColor black
skinparam ParticipantBackgroundColor white
skinparam ParticipantBorderColor black
skinparam SequenceLifeLineBorderColor black
skinparam ArrowColor black
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 0
skinparam defaultFontName DejaVu Sans
skinparam defaultFontSize 11

title Pay Fine

actor Member
boundary PaymentScreen
control PaymentController
entity FineRecord
boundary PaymentForm
control PaymentProcessor
entity PaymentTransaction

Member -> PaymentScreen : viewFine(memberId)
PaymentScreen -> PaymentController : request(memberId)
PaymentController -> FineRecord : retrieve(fineId, amount, issuedDate, status)
FineRecord --> PaymentController : fineDetails
PaymentController --> PaymentScreen : display(fineDetails)
Member -> PaymentForm : pay(fineId, amountPaid, method)
PaymentForm -> PaymentProcessor : process(fineId, amountPaid, method)
PaymentProcessor -> FineRecord : update(fineId, status="Paid")
FineRecord --> PaymentProcessor : confirm()
PaymentProcessor -> PaymentTransaction : create(transactionId, paymentDate, amountPaid, method)
PaymentTransaction --> PaymentProcessor : transactionId
PaymentController --> PaymentScreen : confirm(transactionId)

@enduml
