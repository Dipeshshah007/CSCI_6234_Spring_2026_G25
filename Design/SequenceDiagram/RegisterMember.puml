@startuml RegisterMember
skinparam backgroundColor white
skinparam SequenceBoxBackgroundColor white
skinparam SequenceBoxBorderColor black
skinparam ParticipantBackgroundColor white
skinparam ParticipantBorderColor black
skinparam SequenceLifeLineBorderColor black
skinparam ArrowColor black
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 0
skinparam defaultFontName DejaVu Sans
skinparam defaultFontSize 11

title Register Member

actor Librarian
boundary RegistrationScreen
control RegistrationController
boundary MemberForm
control IDGenerator
entity Member

Librarian -> RegistrationScreen : access()
RegistrationScreen -> RegistrationController : process()
RegistrationController --> RegistrationScreen : displayForm()
Librarian -> MemberForm : enterInfo(name, email, phone, password)
MemberForm -> IDGenerator : validate(memberData)
IDGenerator -> Member : create(memberId, name, email, phone, password, membershipDate, membershipStatus)
Member --> IDGenerator : memberId
IDGenerator --> MemberForm : confirm(memberId)
RegistrationController --> RegistrationScreen : display("Member registered", memberId)

@enduml
